{
  "name": "remit",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Remit — employer-side workforce-flexibility governance. Pure domain core + services + REST API + CLI. Never surveillance.",
  "scripts": {
    "demo": "tsx src/cli.ts",
    "dev": "tsx watch src/api/server.ts",
    "start": "tsx src/api/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
