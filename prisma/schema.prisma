// Remit persistence (Milestone 2). Mirrors src/domain/types.ts. Nested arrays are stored as JSON
// to keep the first cut simple; promote to relations later if you need to query inside them.
// COUNSEL: legal-reference fields are scaffolds; verify before production. Data residency: Australia.
generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

enum Jurisdiction { VIC NSW QLD WA SA TAS ACT NT }
enum RequestStatus { pending flagged approved modified refused }
enum HazardType { psychosocial physical }
enum HazardStatus { ontrack due reviewed }
enum ContractStatus { ontrack review reviewed }

model Organisation {
  id            String   @id @default(cuid())
  name          String
  abn           String?
  industry      String?
  employeeBand  String?
  jurisdictions Jurisdiction[]
  createdAt     DateTime @default(now())
  requests      WfhRequest[]
  hazards       Hazard[]
  contracts     OutcomeContract[]
  priors        PriorDecision[]
}

model WfhRequest {
  id                 String        @id
  org                Organisation  @relation(fields: [orgId], references: [id])
  orgId              String
  employee           String
  role               String
  roleKey            String
  jurisdiction       Jurisdiction
  days               String
  pattern            String
  assessment         Json          // AssessmentFactor[]
  assessmentComplete Boolean       @default(false)
  status             RequestStatus @default(pending)
  consistency        Json          // ConsistencyResult
  decision           Json?         // Decision
  audit              Json          // AuditEvent[]
  createdAt          DateTime      @default(now())
  @@index([orgId, status])
}

model PriorDecision {
  id           String        @id
  org          Organisation  @relation(fields: [orgId], references: [id])
  orgId        String
  roleKey      String
  jurisdiction Jurisdiction
  status       RequestStatus
  role         String?
  days         String?
  decidedOn    String?
  @@index([orgId, roleKey, jurisdiction])
}

model Hazard {
  id           String       @id
  org          Organisation @relation(fields: [orgId], references: [id])
  orgId        String
  name         String
  type         HazardType
  jurisdiction Jurisdiction
  controls     Json         // Control[]
  consultation String
  triggers     Json         // string[]
  status       HazardStatus @default(ontrack)
  reviewDate   String
  audit        Json         // AuditEvent[]
  @@index([orgId, status])
}

model OutcomeContract {
  id           String         @id
  org          Organisation   @relation(fields: [orgId], references: [id])
  orgId        String
  employee     String
  jurisdiction Jurisdiction
  period       String
  outcomes     Json           // Outcome[]
  signalSource String
  status       ContractStatus @default(ontrack)
  audit        Json           // AuditEvent[]
  @@index([orgId, status])
}
